# TrainingSmart AI Environment Variables
# Copy this file to .env and fill in your actual values
# 
# SECURITY WARNING: Never commit your actual .env file to version control!
# These keys should be kept secret and never exposed in frontend code.

# Strava API Configuration
# Only the Client ID is needed in the frontend
VITE_STRAVA_CLIENT_ID=your_strava_client_id
VITE_STRAVA_REDIRECT_URI=http://localhost:5173/auth/callback

# For production, set these in Supabase Edge Function secrets (automatically configured):
# - STRAVA_CLIENT_SECRET (set via Supabase Dashboard)

# Oura Ring API Configuration
VITE_OURA_CLIENT_ID=your_oura_client_id
# Client secret should be moved to backend in production!
VITE_OURA_CLIENT_SECRET=your_oura_client_secret
VITE_OURA_REDIRECT_URI=https://localhost:5173/auth/oura/callback

# OpenAI API Configuration
# Set OPENAI_API_KEY in Supabase Edge Function secrets (not here)

# YouTube API Configuration (for content feed)
# MOVED TO SERVER-SIDE: Set YOUTUBE_API_KEY as a Supabase Edge Function secret.
# Do NOT add a VITE_ prefix — the key is now proxied via the youtube-search Edge Function
# and must never be exposed in the browser bundle.
# To set: supabase secrets set YOUTUBE_API_KEY=your_key

# Google Calendar API Configuration
# To set up:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Google Calendar API
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add authorized redirect URIs: http://localhost:5173/settings and your production URL
# 6. Copy Client ID and Client Secret below
# WARNING: Client secret should be moved to backend in production!
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/settings

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Application Configuration